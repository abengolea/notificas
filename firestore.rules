rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Email en JWT (Google puede usar mayúsculas distintas a lo guardado en documentos).
    function callerEmailRaw() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : '';
    }

    function callerEmailLower() {
      return callerEmailRaw() != ''
        ? callerEmailRaw().lower()
        : '';
    }

    function sameEmail(field) {
      return field is string
        && callerEmailLower() != ''
        && field.lower() == callerEmailLower();
    }

    // Lectura de un mensaje: remitente (UID o campo senderName como email), o destinatario.
    function mailReadable() {
      let createdBy = resource.data.get('createdBy', '');
      let recipientEmail = resource.data.get('recipientEmail', '');
      let senderName = resource.data.get('senderName', '');
      let toList = resource.data.get('to', []);
      return signedIn() && (
        createdBy == request.auth.uid ||
        sameEmail(senderName) ||
        sameEmail(recipientEmail) ||
        (
          toList is list &&
          callerEmailLower() != '' &&
          (callerEmailLower() in toList || callerEmailRaw() in toList)
        )
      );
    }

    // Subconjuntos alineados con las consultas del cliente (allow list separadas; Firestore las OR-ea).
    function mailRecipientInToList() {
      let toList = resource.data.get('to', []);
      return signedIn()
        && callerEmailLower() != ''
        && toList is list
        && (callerEmailLower() in toList || callerEmailRaw() in toList);
    }

    function mailSenderBySenderNameField() {
      let senderName = resource.data.get('senderName', '');
      return signedIn() && callerEmailLower() != '' && senderName is string
        && senderName.lower() == callerEmailLower();
    }

    function mailByCreatedBy() {
      return signedIn() && resource.data.get('createdBy', '') == request.auth.uid;
    }

    function mailByRecipientEmailField() {
      let recipientEmail = resource.data.get('recipientEmail', '');
      return signedIn() && callerEmailLower() != '' && recipientEmail is string
        && recipientEmail.lower() == callerEmailLower();
    }

    // Quien puede leer no debe poder reescribir remitente/destinatario/contenido certificado.
    function mailCoreUnchanged() {
      let r = resource.data;
      let n = request.resource.data;
      return r.get('createdBy', '') == n.get('createdBy', '')
        && r.get('to', []) == n.get('to', [])
        && r.get('message', null) == n.get('message', null)
        && r.get('from', '') == n.get('from', '')
        && r.get('recipientEmail', '') == n.get('recipientEmail', '')
        && r.get('senderName', '') == n.get('senderName', '');
    }

    function mailSenderCanUpdate() {
      return resource.data.get('createdBy', '') == request.auth.uid;
    }

    function mailRecipientSafeUpdate() {
      return mailReadable() && mailCoreUnchanged();
    }

    // tracking / certificaciones Polygon solo vía Admin SDK (API server-side).
    function mailAuditFieldsUnchanged() {
      let r = resource.data;
      let n = request.resource.data;
      return r.get('tracking', null) == n.get('tracking', null)
        && r.get('polygonCertifications', null) == n.get('polygonCertifications', null);
    }

    match /mail/{mailId} {
      allow get: if mailReadable();

      // list: Firebase Auth normaliza los emails a minúsculas en el JWT,
      // por lo que NO se llama .lower() sobre request.auth.token.email —
      // eso rompe la validación simbólica de Firestore para queries list.
      allow list: if request.auth != null
        && (
          (resource.data.to is list && request.auth.token.email in resource.data.to)
          || resource.data.createdBy == request.auth.uid
          || (resource.data.senderName is string
              && resource.data.senderName == request.auth.token.email)
          || (resource.data.recipientEmail is string
              && resource.data.recipientEmail == request.auth.token.email)
        );

      allow create: if signedIn();
      allow update: if signedIn()
        && mailAuditFieldsUnchanged()
        && (mailSenderCanUpdate() || mailRecipientSafeUpdate());
      allow delete: if false;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /transactions/{transactionId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /user_transactions/{txId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Catálogo de planes (p. ej. billetera / getPlans).
    match /plans/{planId} {
      allow read: if resource.data.get('activo', false) == true;
      allow write: if false;
    }

    // Contactos del usuario (colección real en la app: `contactos`, campo `usuarioId`).
    match /contactos/{contactoId} {
      allow read: if signedIn() && resource.data.usuarioId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.usuarioId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.usuarioId == request.auth.uid;
    }

    match /blockchain_movements/{docId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    function orgData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data;
    }

    function isOrgMemberById(orgId) {
      return signedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && (
          orgData(orgId).adminUserId == request.auth.uid
          || request.auth.uid in orgData(orgId).members
          || sameEmail(orgData(orgId).get('adminUserEmail', ''))
        );
    }

    match /organizations/{orgId} {
      allow read: if signedIn() && (
        resource.data.adminUserId == request.auth.uid
        || request.auth.uid in resource.data.members
        || sameEmail(resource.data.get('adminUserEmail', ''))
      );
      allow create: if false;
      allow update: if signedIn() && resource.data.adminUserId == request.auth.uid;
      allow delete: if false;
    }

    match /recipient_lists/{listId} {
      allow read: if signedIn() && isOrgMemberById(resource.data.orgId);

      allow create: if signedIn()
        && request.resource.data.orgId is string
        && request.resource.data.recipients is list
        && isOrgMemberById(request.resource.data.orgId);

      allow update: if signedIn()
        && resource.data.orgId is string
        && isOrgMemberById(resource.data.orgId);

      allow delete: if signedIn()
        && resource.data.orgId is string
        && isOrgMemberById(resource.data.orgId);
    }

    match /campaigns/{campaignId} {
      allow read: if signedIn() && isOrgMemberById(resource.data.orgId);

      allow create: if signedIn()
        && request.resource.data.orgId is string
        && request.resource.data.createdBy == request.auth.uid
        && isOrgMemberById(request.resource.data.orgId);

      allow update: if signedIn()
        && resource.data.orgId is string
        && isOrgMemberById(resource.data.orgId);

      allow delete: if false;
    }

    match /campaign_messages/{msgId} {
      allow read: if signedIn()
        && resource.data.orgId is string
        && isOrgMemberById(resource.data.orgId);
      allow write: if false;
    }

    match /contacts/{contactId} {
      allow read, write: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
