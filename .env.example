# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase credentials

# URL pública de la app (SSR seguro; evita confiar en el header Host)
# Desarrollo: puerto de `npm run dev` (ej. 9006). Producción: https://tudominio.com
# Importante en producción: enlaces del certificado PDF (adjuntos, etc.) usan esta base.
NEXT_PUBLIC_APP_URL=http://localhost:9006

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin SDK (service account - para API routes)
# Obtener de Firebase Console > Project Settings > Service Accounts > Generate new private key
# Puede repetir NEXT_PUBLIC_FIREBASE_PROJECT_ID si no definís FIREBASE_PROJECT_ID aparte.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Panel /admin — login y cookies HttpOnly (/api/admin/*). Generá ADMIN_SESSION_SECRET largo aleatorio (p. ej. openssl rand -hex 32).
ADMIN_PANEL_EMAIL=admin@ejemplo.com
ADMIN_PANEL_PASSWORD=definí_una_fuerte_en_local
ADMIN_SESSION_SECRET=reemplazar_por_secreto_largo_y_único

# Demo módulo empresas (opcional; valores por defecto en scripts/seed-demo-empresa.js)
# DEMO_EMPRESA_EMAIL=demo.empresa@notificas.local
# DEMO_EMPRESA_PASSWORD=DemoEmpresa2026!

# Polygon Mainnet - Red real con POL
# Chain ID: 137 | Currency: POL | Explorer: https://polygonscan.com
# Obtén POL en Binance u otros exchanges

POLYGON_PRIVATE_KEY=your_private_key_without_0x
POLYGON_PROVIDER_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_WALLET_ADDRESS=0xYOUR_DESTINATION_ADDRESS

# Formulario "Contáctenos" — Firestore `mail` + Cloud Function `sendEmail` + SMTP (Donweb).
# Valores por defecto del código (src/lib/mail-defaults.ts); solo descomentá o cambiá si hace falta.
FIREBASE_SENDEMAIL_URL=https://sendemail-ju7n3yysfq-uc.a.run.app
CONTACT_INBOX_EMAIL=contacto@notificas.com
CONTACT_FORM_CREATED_BY=contact-form-web

# Mercado Pago (Checkout Pro): token de la app en developers.mercadopago.com
# El mismo ACCESS_TOKEN debe ser la misma cuenta/seller que use Notificas Hub para GET /v1/payments/{id}.
# MERCADOPAGO_ACCESS_TOKEN=
# Webhook Mercado Pago: dejalo apuntando a esta app para acreditar créditos.
# Si NEXT_PUBLIC_APP_URL no es HTTPS, usá la base pública del deploy de Notificas:
# MERCADOPAGO_WEBHOOK_PUBLIC_BASE_URL=https://tu-dominio-o-apphosting.web.app
# Solo usar MERCADOPAGO_NOTIFICATION_URL si querés forzar la URL completa del webhook de ESTA app.
# MERCADOPAGO_NOTIFICATION_URL=https://notificas.com.ar/api/mercadopago/webhook
# Opcional: query que MP repetirá al notificar (sólo si el Hub valida así; Bearer MP no puede mandar desde MP sin proxy).
# MERCADOPAGO_NOTIFICATION_URL_QUERY=clave=valor
# Hub — hub_emit_factura en metadata (= "true" sólo si esto es exactamente true)
# MERCADOPAGO_HUB_EMIT_FACTURA=true
# Opcional tipo comprobante en metadata (A|B|C)
# MERCADOPAGO_HUB_CBTE_TIPO=B
#
# Facturación ARCA vía Notificas Hub: llamada servidor a servidor después de pago aprobado.
# NOTIFICASHUB_URL=https://notificashub--studio-3864746689-59018.us-east4.hosted.app
# NOTIFICASHUB_BILLING_EMIT_URL=http://localhost:3000/api/integrations/notificas/billing/emit
# NOTIFICAS_BILLING_SHARED_SECRET=misma_clave_en_notificashub
#
# Opcional mapping cliente Hub: campo string hubBillingClienteId en users/{uid} o users/{uid}.perfil.hubBillingClienteId
# = doc id en Firestore del Hub colección billing_recurrente_clients. Si omitís: se usa el Auth uid como doc id esperado.
