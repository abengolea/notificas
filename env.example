# Configuración de Mercado Pago
# Obtén estas credenciales desde https://www.mercadopago.com.ar/developers/panel/credentials

# Credenciales de Producción (usar valores reales solo en .env.local / secretos, nunca commitear)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-tu_access_token
MERCADOPAGO_PUBLIC_KEY=APP_USR-tu_public_key
MERCADOPAGO_CLIENT_ID=tu_client_id_numerico
MERCADOPAGO_CLIENT_SECRET=tu_client_secret

# Configuración del entorno
NODE_ENV=development
MERCADOPAGO_ENVIRONMENT=production

# URLs de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:9006
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-tu_public_key

# Webhook de Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=tu_webhook_secret_aqui

# Configuración de Firebase
FIREBASE_PROJECT_ID=notificas-f9953
FIREBASE_PRIVATE_KEY_ID=tu_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_private_key_aqui\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@notificas-f9953.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=tu_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40notificas-f9953.iam.gserviceaccount.com

# Configuración de Polygon Mainnet (Chain ID: 137)
# Obtén la clave desde MetaMask: Account details > Export Private Key
POLYGON_PRIVATE_KEY=tu_clave_de_metamask_sin_0x_64_caracteres
POLYGON_PROVIDER_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_WALLET_ADDRESS=0xTuDireccionConPOL
# Obligatorio: protege /api/polygon/certify-event (sin esto el endpoint responde 503).
# Mismo valor en App Hosting y Cloud Functions (ver setup-firebase-secrets.sh).
POLYGON_CERTIFY_SECRET=tu_secreto_aleatorio_largo
