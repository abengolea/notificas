# Configuración de Tracking HMAC
TRACKING_HMAC_SECRET=tu_secreto_secreto_de_32_caracteres_minimo_aqui

# Configuración de Polygon (si usas blockchain)
POLYGON_PROVIDER_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_PRIVATE_KEY=tu_clave_privada_de_polygon
POLYGON_WALLET_ADDRESS=tu_direccion_de_wallet_polygon

# URLs de la aplicación
# URL pública de la aplicación (usada en enlaces de correos)
# IMPORTANTE: Siempre usar la URL de producción, incluso en desarrollo local
# Los correos deben apuntar a la URL pública para que los destinatarios puedan acceder
# NUNCA usar localhost aquí, ya que los correos se envían a usuarios reales
APP_HOSTING_URL=https://notificas--notificas-f9953.us-central1.hosted.app
PUBLIC_FUNCTIONS_URL=https://tu-region-tu-proyecto.cloudfunctions.net

# WhatsApp (Meta Cloud API) - Secret Manager en producción
# Para producción: ./scripts/setup-whatsapp-secrets.sh
# Para emulador local: crear functions/.secret.local con:
#   WHATSAPP_ACCESS_TOKEN=tu_token
#   WHATSAPP_PHONE_NUMBER_ID=tu_phone_id
#
# WHATSAPP_TEMPLATE_NAME - OBLIGATORIO para Meta (usuarios que no te escribieron en 24h)
# Template: "Hola {{1}}, {{2}} te ha enviado una notificación digital certificada. Accede aquí: {{3}} Saludos."
# Variables: 1=nombre, 2=remitente, 3=url
WHATSAPP_TEMPLATE_NAME=notificaciones_notificas
